generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum InviteType {
  MEMBER
  FRANCHISE
}

enum MembershipStatus {
  ACTIVE
  RESTRICTED
}

enum FeedbackType {
  ISSUE
  IDEA
}

enum TaskScope {
  ORG    // only the owning org can see it; existing franchisee inheritance rows are kept
  GLOBAL // shared with franchise — franchisees can discover and inherit
}

enum SectionScope {
  ORG    // section interaction is limited to the viewing org
  GLOBAL // section is shared / visible across the franchise network
}

enum PermissionAction {
  MANAGE_MEMBERS
  MANAGE_ROLES
  MANAGE_TIMETABLE
  MANAGE_TASKS
  MANAGE_SETTINGS
  VIEW_TIMETABLE
}

enum EntryStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
  CANCELLED
}

enum ViewType {
  DAILY
  WEEKLY
}

// ─────────────────────────────────────
// AUTH (NextAuth)
// ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────
// 1. USER
// ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?

  memberships               Membership[]
  ownedOrgs                 Organization[] @relation("OrgOwner")
  sentInvites               Invite[]       @relation("SentInvites")
  receivedInvites           Invite[]       @relation("ReceivedInvites")
  receivedNotifications     Notification[] @relation("ReceivedNotifications")
  auditLogs                 AuditLog[]

  feedback      Feedback[]
  createdTasks  Task[]     @relation("CreatedTasks")

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────
// 2. ORGANIZATION
// ─────────────────────────────────────

model Organization {
  id            String   @id @default(cuid())
  name          String
  image         String?

  ownerId       String
  owner         User     @relation("OrgOwner", fields: [ownerId], references: [id])

  // Franchise hierarchy
  parentId      String?
  parent        Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children      Organization[] @relation("OrgHierarchy")

  // Location
  address       String?

  // Operating schedule
  operatingDays String[] // ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
  openTimeMin   Int?
  closeTimeMin  Int?
  timezone      String   @default("Australia/Sydney")

  memberships         Membership[]
  roles               Role[]
  tasks               Task[]
  tags                Tag[]
  timetableEntries    TimetableEntry[]
  timetableSettings   TimetableSettings?
  timetableTemplates  TimetableTemplate[]
  rosterEntries       RosterEntry[]
  rosterDayConfigs    RosterDayConfig[]
  rosterTemplates     RosterTemplate[]
  franchiseTokens     FranchiseToken[]
  invites             Invite[]
  auditLogs           AuditLog[]
  toolItems           ToolItem[]
  conversionSets      ConversionSet[]
  feedback            Feedback[]
  taskInheritances    TaskInheritance[]
  sectionLayouts      TaskSectionLayout[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerId])
  @@index([parentId])
}

// ─────────────────────────────────────
// 3. MEMBERSHIP
// ─────────────────────────────────────

model Membership {
  id            String   @id @default(cuid())

  // Null when this record represents a bot/placeholder (userId is null)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Populated when userId is null (bot/placeholder slot). Exactly one of userId or botName must be non-null.
  botName       String?  // display name for the placeholder

  workingDays   String[] // ["mon", "tue", "wed"]
  status        MembershipStatus @default(ACTIVE)

  memberRoles         MemberRole[]
  taskAssignments     TimetableEntryAssignee[]
  timetableTemplateAssignments TimetableTemplateEntryAssignee[]
  rosterEntries                RosterEntry[]
  rosterTemplateEntries        RosterTemplateEntry[]

  joinedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Real users: one membership per org. Bots have null userId so no unique conflict.
  @@unique([userId, orgId])
  @@unique([id, orgId])
  @@index([orgId])
  @@index([userId])
}

// ─────────────────────────────────────
// 4. ROLE
// ─────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String
  color       String
  key         String   // "owner", "default", "cook"

  orgId       String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  isDeletable Boolean  @default(true)
  isDefault   Boolean  @default(false)

  permissions Permission[]
  memberRoles MemberRole[]
  eligibleFor TaskEligibility[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, key])
  @@index([orgId])
}

// ─────────────────────────────────────
// 5. PERMISSION
// ─────────────────────────────────────

model Permission {
  id          String   @id @default(cuid())
  action      PermissionAction

  roleId      String
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([action, roleId])
  @@index([roleId])
}

// ─────────────────────────────────────
// 6. MEMBER ROLE
// ─────────────────────────────────────

model MemberRole {
  id            String   @id @default(cuid())

  membershipId  String
  membership    Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  roleId        String
  role          Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt    DateTime @default(now())

  @@unique([membershipId, roleId])
  @@index([membershipId])
  @@index([roleId])
}

// ─────────────────────────────────────
// 7. TASK
// ─────────────────────────────────────

model Task {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  color                 String

  orgId                 String
  organization          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Null for tasks created before this field was added, or by system processes.
  createdById           String?
  createdBy             User?        @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: SetNull)
  createdByName         String?      // snapshot — survives user deletion

  durationMin           Int      @default(60)
  minPeople             Int      @default(1)
  maxPeople             Int?
  priority              Int      @default(0)
  preferredStartTimeMin Int?     // 0-1439

  // Recurrence constraints for optimizer
  minWaitDays           Int?
  maxWaitDays           Int?

  imageUrl              String?  // Supabase Storage path (not a signed URL)

  eligibility           TaskEligibility[]
  tags                  TaskTag[]
  timetableEntries      TimetableEntry[]
  timetableTemplateEntries TimetableTemplateEntry[]
  inheritedBy           TaskInheritance[]
  sectionLayouts        TaskSectionLayout[]

  scope                 TaskScope @default(ORG)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([orgId, name])
  @@index([orgId])
  @@index([scope, orgId])
}

// ─────────────────────────────────────
// 8. TASK ELIGIBILITY
// ─────────────────────────────────────

model TaskEligibility {
  id     String @id @default(cuid())
  taskId String
  roleId String

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([taskId, roleId])
  @@index([taskId])
  @@index([roleId])
}

// ─────────────────────────────────────
// 9. TAG
// ─────────────────────────────────────

model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#6B7280")

  // Protects built-in tags (e.g. "Task") from being deleted
  isDefault   Boolean  @default(false)

  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  tasks       TaskTag[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, name])
  @@index([orgId])
}

// ─────────────────────────────────────
// 10. TASK TAG
// ─────────────────────────────────────

model TaskTag {
  taskId  String
  tagId   String

  task    Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag     Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

// ─────────────────────────────────────
// 11. TIMETABLE ENTRY
// ─────────────────────────────────────

model TimetableEntry {
  id            String   @id @default(cuid())

  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Snapshot from Task (frozen at creation time)
  taskName        String
  taskColor       String?
  taskDescription String?

  // Overridable per entry (defaults from Task, editable per day)
  priority      Int      @default(0)
  durationMin   Int

  date          DateTime
  startTimeMin  Int      // 0-1439
  endTimeMin    Int      // 0-1439

  status        EntryStatus @default(TODO)

  assignees     TimetableEntryAssignee[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId])
  @@index([taskId])
  @@index([orgId, date])
}

// ─────────────────────────────────────
// 12. TIMETABLE ENTRY ASSIGNEE
// ─────────────────────────────────────

model TimetableEntryAssignee {
  id                String @id @default(cuid())
  timetableEntryId  String
  membershipId      String

  timetableEntry    TimetableEntry @relation(fields: [timetableEntryId], references: [id], onDelete: Cascade)
  membership        Membership     @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())

  @@unique([timetableEntryId, membershipId])
  @@index([membershipId])
}

// ─────────────────────────────────────
// 13. TIMETABLE SETTINGS
// ─────────────────────────────────────

model TimetableSettings {
  id              String   @id @default(cuid())

  orgId           String   @unique
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  viewType        ViewType @default(WEEKLY)
  startDay        String   @default("mon")
  slotDuration    Int      @default(30)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────
// 14. TIMETABLE TEMPLATE
// ─────────────────────────────────────

model TimetableTemplate {
  id              String   @id @default(cuid())
  name            String

  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  cycleLengthDays Int      @default(7)

  entries         TimetableTemplateEntry[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([name, orgId])
  @@index([orgId])
}

model TimetableTemplateEntry {
  id            String   @id @default(cuid())

  templateId    String
  template      TimetableTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Overridable per entry
  priority      Int      @default(0)
  durationMin   Int?     // null = use Task default

  dayIndex      Int      // 0 to cycleLengthDays - 1
  startTimeMin  Int      // 0-1439
  endTimeMin    Int      // 0-1439

  assignees     TimetableTemplateEntryAssignee[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TimetableTemplateEntryAssignee {
  id                String @id @default(cuid())
  templateEntryId   String
  membershipId      String

  templateEntry     TimetableTemplateEntry @relation(fields: [templateEntryId], references: [id], onDelete: Cascade)
  membership        Membership             @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())

  @@unique([templateEntryId, membershipId])
  @@index([membershipId])
}

// ─────────────────────────────────────
// ROSTER
// ─────────────────────────────────────

model RosterEntry {
  id           String   @id @default(cuid())

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  membershipId    String
  membershipOrgId String
  membership      Membership @relation(fields: [membershipId, membershipOrgId], references: [id, orgId], onDelete: Cascade)

  weekStart    DateTime // Always Monday 00:00:00 UTC
  dayIndex     Int      // 0=Mon … 6=Sun

  shiftStartMin Int?   // null = unspecified / all day
  shiftEndMin   Int?   // 0-1440

  note         String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([orgId, membershipId, weekStart, dayIndex])
  @@index([orgId, weekStart])
  @@index([membershipId])
}

model RosterDayConfig {
  id              String @id @default(cuid())

  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  dayIndex        Int    // 0=Mon … 6=Sun
  recommendedSize Int    @default(1)
  openTimeMin     Int?   // null = inherit org default
  closeTimeMin    Int?   // 0-1440

  @@unique([orgId, dayIndex])
  @@index([orgId])
}

model RosterTemplate {
  id        String   @id @default(cuid())
  name      String
  cycleWeeks Int     @default(1) // Number of weeks in this template cycle

  orgId     String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  entries   RosterTemplateEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
  @@index([orgId])
}

model RosterTemplateEntry {
  id           String   @id @default(cuid())

  templateId   String
  template     RosterTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  membershipId    String
  membershipOrgId String
  membership      Membership @relation(fields: [membershipId, membershipOrgId], references: [id, orgId], onDelete: Cascade)

  weekIndex     Int   @default(0) // 0-based week within the template cycle
  dayIndex      Int   // 0=Mon … 6=Sun
  shiftStartMin Int?  // null = unspecified / all day
  shiftEndMin   Int?  // 0-1440
  note          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateId, membershipId, weekIndex, dayIndex])
  @@index([templateId])
  @@index([membershipId])
}

// ─────────────────────────────────────
// 15. FRANCHISE TOKEN
// ─────────────────────────────────────

model FranchiseToken {
  id           String   @id @default(cuid())
  token        String   @unique @default(cuid())

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  invitedEmail String
  usedByOrgId  String?  @unique

  expiresAt    DateTime
  acceptedAt   DateTime?

  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────
// 16. INVITE
// ─────────────────────────────────────

model Invite {
  id          String       @id @default(cuid())

  orgId       String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Nullable so invite history is preserved if inviter's account is deleted
  invitedById String?
  invitedBy   User?        @relation("SentInvites", fields: [invitedById], references: [id], onDelete: SetNull)

  recipientId String
  recipient   User         @relation("ReceivedInvites", fields: [recipientId], references: [id], onDelete: Cascade)

  type        InviteType
  status      InviteStatus @default(PENDING)

  // Snapshot fields — captured at creation so cards render without extra joins
  orgName     String
  inviterName String?

  // Stores intent data for accept step (e.g. { roleIds: string[], workingDays: string[] })
  metadata    Json?

  expiresAt   DateTime?
  seenAt      DateTime?
  acceptedAt  DateTime?
  declinedAt  DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([orgId])
  @@index([recipientId])
  @@index([invitedById])
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// Simple in-app notification records created by server-side events.
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())

  /// The user who should see this notification.
  userId    String
  user      User     @relation("ReceivedNotifications", fields: [userId], references: [id], onDelete: Cascade)

  /// Short human-readable message, e.g. "Alice accepted your invitation to Acme Corp."
  message   String

  /// When the user opened/dismissed the notification.
  seenAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG
// Immutable record of significant mutations. Created inside the same
// transaction as the mutation so logs are always consistent with the DB state.
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  orgId      String   // tenant scope — always indexed
  actorId    String?  // userId of who did it (null for system actions)
  actorEmail String?  // snapshot — survives user deletion
  action     String   // e.g. "task.create", "membership.delete", "role.update"
  targetType String   // e.g. "Task", "Membership", "Role"
  targetId   String   // ID of the affected entity
  before     Json?    // snapshot of entity before mutation (null for creates)
  after      Json?    // snapshot of entity after mutation (null for deletes)
  metadata   Json?    // freeform extra context (IP, request ID, etc.)
  createdAt  DateTime @default(now())

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([orgId, targetType, targetId])
  @@index([orgId, actorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// TOOL ITEMS
// Shared ingredient/product catalogue scoped to an org.
// Used as the common anchor for conversion sets and (future) data logs.
// ─────────────────────────────────────────────────────────────────────────────

model ToolItem {
  id        String   @id @default(cuid())
  name      String
  unit      String   // user-typed label, e.g. "each", "g", "ml"
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ratesFrom            ConversionRate[]          @relation("RateFromItem")
  ratesTo              ConversionRate[]          @relation("RateToItem")
  templateEntries      ConversionTemplateEntry[]

  @@unique([orgId, name])
  @@index([orgId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONVERSION SET
// Named grouping that owns its own rates.
// e.g. "Donut Production", "Bread Production"
// ─────────────────────────────────────────────────────────────────────────────

model ConversionSet {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rates     ConversionRate[]
  templates ConversionTemplate[]

  @@unique([orgId, name])
  @@index([orgId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONVERSION RATE
// 1-to-many: one fromItem can produce multiple toItems within a set.
// Rate is scoped to the set — same item pair can have different rates per set.
// ─────────────────────────────────────────────────────────────────────────────

model ConversionRate {
  id         String  @id @default(cuid())
  setId      String
  fromItemId String
  toItemId   String
  fromQty    Float   @default(1) // numerator the user entered
  toQty      Float   @default(1) // denominator the user entered
  // rate scalar is computed on the fly as toQty / fromQty

  set      ConversionSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  fromItem ToolItem      @relation("RateFromItem", fields: [fromItemId], references: [id], onDelete: Cascade)
  toItem   ToolItem      @relation("RateToItem",   fields: [toItemId],   references: [id], onDelete: Cascade)

  @@unique([setId, fromItemId, toItemId])
  @@index([setId])
  @@index([fromItemId])
  @@index([toItemId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONVERSION TEMPLATE
// Named preset of input quantities for a conversion set.
// e.g. "Monday Batch" with 200 donuts.
// ─────────────────────────────────────────────────────────────────────────────

model ConversionTemplate {
  id        String   @id @default(cuid())
  name      String
  setId     String
  set       ConversionSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries            ConversionTemplateEntry[]

  @@unique([setId, name])
  @@index([setId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONVERSION TEMPLATE ENTRY
// One row per (template, item) — only exists when there is something non-default
// to store. Rows serve three purposes (any combination):
//   quantity         — input value saved in the template (e.g. 200 donuts)
//   overrideQuantity — user manually changed a computed output (e.g. 400g custard)
//                      excess = overrideQuantity - (input * rate), computed on load
//   visible          — false when user hid this output item; defaults to true
// ─────────────────────────────────────────────────────────────────────────────

model ConversionTemplateEntry {
  id           String @id @default(cuid())
  templateId   String
  itemId       String
  quantity     Float? // saved input quantity; null when item is to-side only
  // Side flag: 0=hidden, 1=from only, 2=to only, 3=both from and to
  pinnedOutput Int    @default(0)

  template ConversionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  item     ToolItem            @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([templateId, itemId])
  @@index([templateId])
  @@index([itemId])
}

// ─────────────────────────────────────
// FEEDBACK
// ─────────────────────────────────────

model Feedback {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())

  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgId     String?
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  type      FeedbackType
  message   String
  imageUrl  String?  // Supabase Storage path in friendchise-public bucket

  reviewed  Boolean @default(false)

  @@index([userId])
  @@index([orgId])
  @@index([createdAt])
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────
// TASK INHERITANCE
// ─────────────────────────────────────

/// Tracks which orgs have added a GLOBAL task to their task list.
/// Created when a franchisee clicks "Add" on a shared task.
/// Deleting this row removes the task from that org's list.
model TaskInheritance {
  id          String       @id @default(cuid())
  taskId      String
  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inheritedAt DateTime     @default(now())

  @@unique([taskId, orgId])
  @@index([taskId])
  @@index([orgId])
}

// ─────────────────────────────────────
// TASK SECTION LAYOUT
// ─────────────────────────────────────

/// Per-org, per-task section configuration.
/// Stores the position, visibility, scope, and display title of each section
/// (e.g. "PICTURE", "DETAIL", "COMMENT") for a given org's view of a task.
/// When a task is inherited, the parent's layout is copied as a starting point.
model TaskSectionLayout {
  id       String       @id @default(cuid())
  taskId   String
  task     Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  orgId    String
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  /// Flexible string key — not an enum so new section types need no migration.
  /// Known values: "PICTURE", "DETAIL", "COMMENT"
  type     String
  title    String       // display name; orgs can rename later
  scope    SectionScope @default(ORG)
  position Int          // 0 = top; larger = further down
  visible  Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, orgId, type])
  @@index([taskId, orgId])
}