{
  "name": "friendchise",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "migrate:prod": "SKIP_DOTENV_LOCAL=1 dotenv -e .env -- prisma migrate deploy",
    "seed": "prisma db seed",
    "seed:dev": "prisma db seed",
    "seed:clean": "tsx prisma/seed-clean.ts",
    "seed:donut-a": "tsx scripts/seeds/seed-donut-shop-a.ts",
    "seed:donut-a:reset": "tsx scripts/seeds/seed-donut-shop-a.ts --reset",
    "seed:donut-a:bots": "tsx scripts/seeds/populate-donut-shop-a-bots.ts",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:services": "vitest run __tests__/unit/lib/services",
    "test:validators": "vitest run __tests__/unit/lib/validators",
    "test:actions": "vitest run __tests__/unit/app/actions",
    "test:api": "vitest run __tests__/unit/app/api",
    "test:integration": "vitest run --config vitest.integration.ts",
    "test:e2e": "playwright test"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@sentry/nextjs": "^10.50.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tiptap/extension-image": "3.23.6",
    "@tiptap/extension-link": "3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vvo/tzdb": "^6.198.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tiptap-markdown": "^0.9.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "shadcn": "^4.0.8",
    "stylelint": "^17.4.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
